ENV=development
LOG_LEVEL=INFO

# ----------------------------
# LLM Provider
# ----------------------------
# Required for any LLM-powered routing / SQL generation / RAG answer generation
OPENAI_API_KEY=

# Optional: override model inside code (if you add support)
# OPENAI_MODEL=gpt-4o-mini

# ----------------------------
# Internal SQLite (Staffing)
# ----------------------------
DATABASE_PATH=data/staffing.db

# ----------------------------
# Web / CORS
# ----------------------------
# Comma-separated list used in production mode. In development we allow localhost:* automatically.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ----------------------------
# Semantic Cache (SQLite)
# ----------------------------
# Default is data/cache.db (handled in code). Override by editing backend/src/cache/cache_repository.py if needed.
# CACHE_DB_PATH=data/cache.db
# CACHE_TTL_SECONDS=3600

# ----------------------------
# Vector Store (Chroma)
# ----------------------------
# Default is data/chroma (handled in code). Keep data/ at repo root unless you change code paths.
# CHROMA_PATH=data/chroma

# ----------------------------
# MCP Tools (External Tools Registry)
# ----------------------------
# JSON array of tool specs:
# [
#   {"name":"tool_name","description":"...","url":"https://...","method":"POST","timeout_seconds":10}
# ]
MCP_TOOLS_JSON=[]

# ----------------------------
# External Postgres (Office / Resources)
# ----------------------------
# Direct Postgres DSN (optional; used by OfficeEngine when configured)
OFFICE_DB_DSN=

# Direct Postgres DSN (alias). You can set this to Supabase Postgres:
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.bcuzrxharulwczmlvlcp.supabase.co:5432/postgres
DATABASE_URL=

# ----------------------------
# Supabase (PostgREST API) - External DB access via API
# ----------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------
# System Defaults
# ----------------------------
# Default user used by the app if client doesn't provide one
DEFAULT_USER_ID=carol.chen
